{
  "name": "AI 教學實戰營 Day 2",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install --no-cache-dir -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python"
      ],
      "settings": {
        "files.encoding": "utf8",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
